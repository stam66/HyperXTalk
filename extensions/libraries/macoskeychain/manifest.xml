<package version="0.0">
  <name>com.hyperxtalk.macoskeychain</name>
  <title>macOS Keychain</title>
  <author>HyperXTalk</author>
  <description>Wraps macOS Keychain Services to store, retrieve, update and delete generic and internet passwords.</description>
  <version>1.0.0</version>
  <platforms>desktop</platforms>
  <os>mac</os>
  <license>community</license>
  <type>library</type>
  <requires name="com.livecode.foreign"/>
  <requires name="com.livecode.objc"/>
  <requires name="com.livecode.arithmetic"/>
  <requires name="com.livecode.binary"/>
  <requires name="com.livecode.list"/>
  <requires name="com.livecode.logic"/>
  <requires name="com.livecode.string"/>
  <requires name="com.livecode.type"/>
  <handler name="keychainDescribeError" parameters="in integer" return="string"/>
  <handler name="keychainAddGenericPassword" parameters="in string,in string,in string" return="string"/>
  <handler name="keychainUpdateGenericPassword" parameters="in string,in string,in string" return="string"/>
  <handler name="keychainDeleteGenericPassword" parameters="in string,in string" return="string"/>
  <handler name="keychainGenericPasswordExists" parameters="in string,in string" return="boolean"/>
  <handler name="keychainSetGenericPassword" parameters="in string,in string,in string" return="string"/>
  <handler name="keychainAddInternetPassword" parameters="in string,in string,in string,in integer" return="string"/>
  <handler name="keychainDeleteInternetPassword" parameters="in string,in string" return="string"/>
</package>