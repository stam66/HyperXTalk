<package version="0.0">
  <name>com.hyperxtalk.macoscontacts</name>
  <title>macOS Contacts</title>
  <author>HyperXTalk</author>
  <description>Provides access to the macOS Contacts framework</description>
  <version>1.0.0</version>
  <license>community</license>
  <type>library</type>
  <requires name="com.livecode.foreign"/>
  <requires name="com.livecode.objc"/>
  <requires name="com.livecode.engine"/>
  <requires name="com.livecode.arithmetic"/>
  <requires name="com.livecode.binary"/>
  <requires name="com.livecode.list"/>
  <requires name="com.livecode.logic"/>
  <requires name="com.livecode.string"/>
  <requires name="com.livecode.type"/>
  <requires name="com.livecode.array"/>
  <requires name="com.livecode.char"/>
  <requires name="com.livecode.byte"/>
  <metadata key="platform">mac</metadata>
  <handler name="contactsAccessPoll" parameters="" return="integer"/>
  <handler name="contactsDiagnostic" parameters="" return="nothing"/>
  <handler name="contactsInitialize" parameters="" return="boolean"/>
  <handler name="contactsRequestAccessGlue" parameters="" return="nothing"/>
  <handler name="contactsAuthorizationStatus" parameters="" return="string"/>
  <handler name="contactsRequestAccess" parameters="" return="string"/>
  <handler name="contactsFetchAll" parameters="" return="list"/>
  <handler name="contactsFetchByName" parameters="in string" return="list"/>
  <handler name="contactsFetchByEmail" parameters="in string" return="list"/>
  <handler name="contactsFetchByPhone" parameters="in string" return="list"/>
  <handler name="contactsCreate" parameters="in array" return="string"/>
  <handler name="contactsDelete" parameters="in string" return="boolean"/>
  <handler name="contactsUpdate" parameters="in string,in array" return="boolean"/>
  <handler name="contactsGroups" parameters="" return="list"/>
  <handler name="contactsFetchByGroup" parameters="in string" return="list"/>
</package>